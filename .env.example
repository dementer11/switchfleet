NCP_ENVIRONMENT=local
NCP_DATABASE_URL=postgresql+psycopg://ncp:ncp@localhost:5432/ncp
NCP_REDIS_URL=redis://localhost:6379/0
NCP_SECRET_KEY=replace-this-with-a-long-random-secret
NCP_ALLOW_REAL_DEVICE_APPLY=false
NCP_BACKUP_BEFORE_APPLY=true
NCP_DEFAULT_BATCH_SIZE=10
NCP_COMMAND_TIMEOUT_SECONDS=60
NCP_CONNECT_TIMEOUT_SECONDS=15
